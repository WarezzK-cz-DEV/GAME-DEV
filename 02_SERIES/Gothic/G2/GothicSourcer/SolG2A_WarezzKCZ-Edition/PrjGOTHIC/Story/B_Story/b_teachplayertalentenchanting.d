	if(enchantmastery == ENCHANTMASTERY_2)
	{
		Npc_SetTalentSkill(oth,NPC_TALENT_ENCHANTING,3);
		PLAYER_TALENT_ENCHANTING[2] = TRUE;
		if(hero.attribute[ATR_DEXTERITY] < 160)
